{
  "name": "markov",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.config.cjs",
  "scripts": {
    "dev": "node ./scripts/dev-with-port-guard.mjs",
    "dev:stack": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\" \"npm run electron\"",
    "dev:web": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p server/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:node": "node --test --import tsx \"server/tests/*.test.ts\"",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "electron": "wait-on tcp:53210 http://localhost:53211/api/health && electron .",
    "electron-dev": "npm run dev",
    "build-electron": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --publish=never"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "chokidar": "^3.5.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "file-saver": "^2.0.5",
    "gray-matter": "^4.0.0",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.2",
    "juice": "^11.0.1",
    "lucide-react": "^0.294.0",
    "markdown-it": "^14.1.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-implicit-figures": "^0.12.0",
    "markdown-it-ruby": "^1.1.2",
    "markdown-it-table-of-contents": "^1.0.0",
    "multer": "^1.4.5-lts.1",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-3d": "^1.24.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.1",
    "streamdown": "^2.3.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.1.0",
    "concurrently": "^8.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "jsdom": "^28.1.0",
    "sass": "^1.90.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0",
    "vitest": "^4.1.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.markov.desktop",
    "productName": "MoRos",
    "directories": {
      "output": "dist-electron8"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron.config.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**",
      "server/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
